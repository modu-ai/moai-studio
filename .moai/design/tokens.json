      "container.position": { "$value": "absolute top-right", "$type": "string" },
      "container.padding":  { "$value": "10px 14px",          "$type": "dimension" },
      "input.height":       { "$value": "26px",               "$type": "dimension" },
      "input.fontSize":     { "$value": "12px",               "$type": "dimension" },
      "ibtn.size":          { "$value": "26px",               "$type": "dimension", "$description": "icon button — Aa, .*, |abc|, etc." }
    },

