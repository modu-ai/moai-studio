      "padding":       { "$value": "12px 14px", "$type": "dimension" },
      "radius":        { "$value": "8px",   "$type": "dimension" },
      "tag.colors": {
        "ANCHOR": { "$value": "#d4a017", "$type": "color", "$description": "gold ★" },
        "WARN":   { "$value": "#c47b2a", "$type": "color", "$description": "amber ⚠" },
        "NOTE":   { "$value": "#2a8a8c", "$type": "color", "$description": "info ●" },
        "TODO":   { "$value": "#6a4cc7", "$type": "color", "$description": "violet ◇" }
      }
