    "md":        { "$value": "0 4px 12px rgba(9,17,15,0.08)", "$type": "shadow" },
    "lg":        { "$value": "0 8px 24px rgba(9,17,15,0.10)", "$type": "shadow" },
    "xl":        { "$value": "0 16px 48px rgba(9,17,15,0.12)","$type": "shadow" },
    "signature": { "$value": "0 8px 32px rgba(20,74,70,0.20)","$type": "shadow", "$description": "hover only — 청록 글로우" }
  },

  "motion": {
    "duration": {
