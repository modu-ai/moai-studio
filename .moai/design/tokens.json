      "100": { "$value": "#eaeaea", "$type": "color" },
      "200": { "$value": "#d4d4d4", "$type": "color" },
      "300": { "$value": "#bcbcbc", "$type": "color" },
      "400": { "$value": "#959595", "$type": "color" },
      "500": { "$value": "#6e6e6e", "$type": "color" },
      "600": { "$value": "#4c4c4c", "$type": "color" },
      "700": { "$value": "#2e2e2e", "$type": "color" },
      "800": { "$value": "#1a1f1d", "$type": "color" },
      "900": { "$value": "#0e1513", "$type": "color" },
      "950": { "$value": "#09110f", "$type": "color" }
