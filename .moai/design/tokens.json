    "semantic": {
      "success": { "$value": "#1c7c70", "$type": "color", "$description": "Test pass, build success, AC GREEN — moai 청록 계열" },
      "warning": { "$value": "#c47b2a", "$type": "color", "$description": "Lint warning, deprecated API, TODO" },
      "danger":  { "$value": "#c44a3a", "$type": "color", "$description": "Compile error, test failure, critical" },
      "info":    { "$value": "#2a8a8c", "$type": "color", "$description": "Hint, note, neutral notification — 사이언" }
    },

    "ide_accent": {
      "$description": "IDE 시안 surface 액센트 (tweakable per chat decision — teal default / blue / violet / cyan).",
      "teal":   { "$value": "#144a46", "$type": "color", "$description": "Default — 브랜드 정합 우선" },
      "blue":   { "$value": "#2563EB", "$type": "color" },
      "violet": { "$value": "#6a4cc7", "$type": "color" },
      "cyan":   { "$value": "#06B6D4", "$type": "color" },
      "amber":  { "$value": "#c47b2a", "$type": "color" },
      "crimson":{ "$value": "#c44a3a", "$type": "color" },
      "mint":   { "$value": "#1c7c70", "$type": "color" }
    },

    "gradient": {
      "$description": "Signature gradient — 브랜드 코어 자산 (절대 분해 금지)",
      "signature":      { "$value": "linear-gradient(135deg, #144a46 0%, #09110f 100%)", "$type": "gradient" },
      "signature.soft": { "$value": "linear-gradient(135deg, rgba(20,74,70,0.08) 0%, rgba(9,17,15,0.04) 100%)", "$type": "gradient" },
      "signature.dark": { "$value": "linear-gradient(135deg, #22938a 0%, #144a46 100%)", "$type": "gradient", "$description": "다크 모드용" }
    },

    "theme": {
      "dark": {
        "$description": "Default theme (developer-friendly, terminal-dominant). 모두의AI Notion 시스템 + IDE surface 토큰.",
        "background": {
          "app":     { "$value": "#0a100e", "$type": "color", "$description": "IDE 시안 d-bg" },
          "panel":   { "$value": "#0e1513", "$type": "color" },
          "surface": { "$value": "#131c19", "$type": "color" },
          "elevated":{ "$value": "#182320", "$type": "color" }
        },
        "text": {
          "primary":   { "$value": "#e6ebe9", "$type": "color" },
          "secondary": { "$value": "#98a09d", "$type": "color" },
          "tertiary":  { "$value": "#6b7370", "$type": "color" },
          "disabled":  { "$value": "#4c4c4c", "$type": "color" },
          "on_primary":{ "$value": "#e8f3f2", "$type": "color" }
        },
        "border": {
          "subtle": { "$value": "rgba(255,255,255,0.06)", "$type": "color" },
          "default":{ "$value": "rgba(255,255,255,0.07)", "$type": "color" },
          "strong": { "$value": "rgba(255,255,255,0.14)", "$type": "color" },
          "focus":  { "$value": "{color.brand.primary.dark}", "$type": "color" }
        },
        "accent": {
          "base":  { "$value": "{color.brand.primary.dark}", "$type": "color" },
          "soft":  { "$value": "rgba(20,74,70,0.14)", "$type": "color" },
          "glow":  { "$value": "rgba(20,74,70,0.22)", "$type": "color" }
        }
      },

      "light": {
        "$description": "Light theme — 모두의AI Notion 시스템.",
        "background": {
          "app":     { "$value": "#f3f3f3", "$type": "color" },
          "panel":   { "$value": "#ffffff", "$type": "color" },
          "surface": { "$value": "#fafaf9", "$type": "color" },
          "elevated":{ "$value": "#ffffff", "$type": "color" }
        },
        "text": {
          "primary":   { "$value": "#09110f", "$type": "color" },
          "secondary": { "$value": "#4c4c4c", "$type": "color" },
          "tertiary":  { "$value": "#8a908e", "$type": "color" },
          "disabled":  { "$value": "#bcbcbc", "$type": "color" },
          "on_primary":{ "$value": "#ffffff", "$type": "color" }
        },
        "border": {
          "subtle": { "$value": "#eaeaea", "$type": "color" },
          "default":{ "$value": "#e6e6e3", "$type": "color" },
          "strong": { "$value": "#d4d4d0", "$type": "color" },
          "focus":  { "$value": "{color.brand.primary}", "$type": "color" }
        },
        "accent": {
          "base":  { "$value": "{color.brand.primary}", "$type": "color" },
          "soft":  { "$value": "rgba(20,74,70,0.14)", "$type": "color" },
          "glow":  { "$value": "rgba(20,74,70,0.22)", "$type": "color" }
        }
      }
    },

    "syntax": {
      "$description": "Code editor / Markdown 코드블록 syntax highlight (tree-sitter scope mapping). Light/dark 분기 키 일부 존재.",
      "keyword.dark":  { "$value": "#c792ea", "$type": "color" },
      "keyword.light": { "$value": "#5e3bb0", "$type": "color" },
      "string.dark":   { "$value": "#88b780", "$type": "color" },
      "string.light":  { "$value": "#1c7c70", "$type": "color" },
      "number":        { "$value": "#c47b2a", "$type": "color" },
      "comment":       { "$value": "#6b7370", "$type": "color" },
      "function.dark": { "$value": "#4f9fce", "$type": "color" },
      "function.light":{ "$value": "#155b8a", "$type": "color" },
      "type":          { "$value": "#d4a45c", "$type": "color" },
      "operator":      { "$value": "#6fc2c2", "$type": "color" },
      "variable":      { "$value": "#e6ebe9", "$type": "color" },
      "constant":      { "$value": "#c44a3a", "$type": "color" },
      "tag":           { "$value": "#c44a3a", "$type": "color" },
      "attribute":     { "$value": "#d4a45c", "$type": "color" }
    }
  },

  "typography": {
    "fontFamily": {
      "sans":  { "$value": ["Pretendard", "system-ui", "-apple-system", "BlinkMacSystemFont", "Segoe UI", "Roboto", "sans-serif"], "$type": "fontFamily", "$description": "Brand font — 모두의AI 공식 (.moai/design/from-claude-design/project/fonts/ 에 9 weight self-hosted .otf)." },
      "latin": { "$value": ["Inter", "system-ui", "sans-serif"], "$type": "fontFamily", "$description": "lang=en 영문 전용 (Pretendard 보완)." },
      "mono":  { "$value": ["JetBrains Mono", "ui-monospace", "SF Mono", "Menlo", "Consolas", "monospace"], "$type": "fontFamily", "$description": "Code / terminal — ligatures." }
    },
    "fontWeight": {
      "thin":       { "$value": 100, "$type": "fontWeight" },
      "extralight": { "$value": 200, "$type": "fontWeight" },
      "light":      { "$value": 300, "$type": "fontWeight" },
      "regular":    { "$value": 400, "$type": "fontWeight" },
      "medium":     { "$value": 500, "$type": "fontWeight" },
      "semibold":   { "$value": 600, "$type": "fontWeight" },
      "bold":       { "$value": 700, "$type": "fontWeight" },
      "extrabold":  { "$value": 800, "$type": "fontWeight" },
      "black":      { "$value": 900, "$type": "fontWeight" }
    },
    "fontSize": {
      "xs":      { "$value": "0.75rem",  "$type": "dimension", "$description": "12px — caption" },
      "sm":      { "$value": "0.875rem", "$type": "dimension", "$description": "14px — body tight" },
      "base":    { "$value": "1rem",     "$type": "dimension", "$description": "16px — body" },
      "lg":      { "$value": "1.125rem", "$type": "dimension", "$description": "18px — h4" },
      "xl":      { "$value": "1.25rem",  "$type": "dimension", "$description": "20px" },
      "2xl":     { "$value": "1.5rem",   "$type": "dimension", "$description": "24px — h3" },
      "3xl":     { "$value": "1.875rem", "$type": "dimension", "$description": "30px — h2" },
      "4xl":     { "$value": "2.25rem",  "$type": "dimension", "$description": "36px — h1" },
      "5xl":     { "$value": "3rem",     "$type": "dimension", "$description": "48px" },
      "6xl":     { "$value": "3.75rem",  "$type": "dimension", "$description": "60px" },
      "display": { "$value": "clamp(2.25rem, 4.5vw, 4rem)", "$type": "dimension", "$description": "히어로 (responsive)" }
