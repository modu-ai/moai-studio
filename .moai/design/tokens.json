      "bounce": { "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)","$type": "cubicBezier" },
      "smooth": { "$value": "cubic-bezier(0.16, 1, 0.3, 1)",    "$type": "cubicBezier" }
    },
    "reduced_motion": { "$value": "1ms", "$type": "duration", "$description": "prefers-reduced-motion 시 모든 transition/animation duration 강제" }
  },

