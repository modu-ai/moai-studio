{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "version": "1.0.0",
  "lastUpdated": "2026-04-25",
  "source": "moai brand identity (모두의AI) + agentic coding IDE conventions (Zed/VS Code/Cursor)",
  "note": "Notion source pending. Path A — Claude Design import 시 본 tokens.json 을 input 으로 사용 가능. /moai design workflow canonical input.",

  "color": {
    "brand": {
      "primary": {
        "50":  { "$value": "#EEF4FF", "$type": "color" },
        "100": { "$value": "#D9E5FF", "$type": "color" },
        "200": { "$value": "#B5C9FF", "$type": "color" },
        "300": { "$value": "#86A4FF", "$type": "color" },
        "400": { "$value": "#5479FB", "$type": "color" },
        "500": { "$value": "#2563EB", "$type": "color", "$description": "Primary brand color — moai blue. CTA, active states, focus rings." },
        "600": { "$value": "#1D4ED8", "$type": "color" },
        "700": { "$value": "#1E40AF", "$type": "color" },
        "800": { "$value": "#1E3A8A", "$type": "color" },
        "900": { "$value": "#172554", "$type": "color" }
      },
      "secondary": {
        "500": { "$value": "#8B5CF6", "$type": "color", "$description": "AI accent (violet) — agent activity, AI-generated content highlight." }
      },
      "accent": {
        "500": { "$value": "#06B6D4", "$type": "color", "$description": "Cyan — link, secondary action, terminal highlight." }
      }
    },

    "neutral": {
      "0":   { "$value": "#FFFFFF", "$type": "color" },
      "50":  { "$value": "#FAFAFA", "$type": "color" },
      "100": { "$value": "#F4F4F5", "$type": "color" },
      "200": { "$value": "#E4E4E7", "$type": "color" },
      "300": { "$value": "#D4D4D8", "$type": "color" },
      "400": { "$value": "#A1A1AA", "$type": "color" },
      "500": { "$value": "#71717A", "$type": "color" },
      "600": { "$value": "#52525B", "$type": "color" },
      "700": { "$value": "#3F3F46", "$type": "color" },
      "800": { "$value": "#27272A", "$type": "color" },
      "900": { "$value": "#18181B", "$type": "color" },
      "950": { "$value": "#09090B", "$type": "color" }
    },

    "semantic": {
      "success": { "$value": "#10B981", "$type": "color", "$description": "Test pass, build success, AC GREEN." },
      "warning": { "$value": "#F59E0B", "$type": "color", "$description": "Lint warning, deprecated API, TODO." },
      "error":   { "$value": "#EF4444", "$type": "color", "$description": "Compile error, test failure, critical." },
      "info":    { "$value": "#3B82F6", "$type": "color", "$description": "Hint, note, neutral notification." }
    },

    "theme": {
      "dark": {
        "$description": "Default theme (developer-friendly, terminal-dominant)",
        "background": {
          "app":     { "$value": "{color.neutral.950}", "$type": "color" },
          "panel":   { "$value": "{color.neutral.900}", "$type": "color" },
          "surface": { "$value": "{color.neutral.800}", "$type": "color" },
          "elevated":{ "$value": "{color.neutral.700}", "$type": "color" }
        },
        "text": {
          "primary":   { "$value": "{color.neutral.50}",  "$type": "color" },
          "secondary": { "$value": "{color.neutral.300}", "$type": "color" },
          "tertiary":  { "$value": "{color.neutral.400}", "$type": "color" },
          "disabled":  { "$value": "{color.neutral.600}", "$type": "color" },
          "link":      { "$value": "{color.brand.accent.500}", "$type": "color" }
        },
        "border": {
          "subtle": { "$value": "{color.neutral.800}", "$type": "color" },
          "default":{ "$value": "{color.neutral.700}", "$type": "color" },
          "strong": { "$value": "{color.neutral.600}", "$type": "color" },
          "focus":  { "$value": "{color.brand.primary.500}", "$type": "color" }
        },
        "toolbar": {
          "background":      { "$value": "{color.neutral.900}", "$type": "color" },
          "tab.active.background":   { "$value": "{color.neutral.800}", "$type": "color" },
          "tab.inactive.background": { "$value": "{color.neutral.900}", "$type": "color" }
        },
        "status": {
          "success": { "$value": "{color.semantic.success}", "$type": "color" },
          "warning": { "$value": "{color.semantic.warning}", "$type": "color" },
          "error":   { "$value": "{color.semantic.error}",   "$type": "color" },
          "info":    { "$value": "{color.semantic.info}",    "$type": "color" }
        },
        "chart": {
          "1": { "$value": "#60A5FA", "$type": "color" },
          "2": { "$value": "#A78BFA", "$type": "color" },
          "3": { "$value": "#34D399", "$type": "color" },
          "4": { "$value": "#FBBF24", "$type": "color" },
          "5": { "$value": "#F87171", "$type": "color" }
        }
      },

      "light": {
        "$description": "Light theme (alternative)",
        "background": {
          "app":     { "$value": "{color.neutral.0}",   "$type": "color" },
          "panel":   { "$value": "{color.neutral.50}",  "$type": "color" },
          "surface": { "$value": "{color.neutral.100}", "$type": "color" },
          "elevated":{ "$value": "{color.neutral.0}",   "$type": "color" }
        },
        "text": {
          "primary":   { "$value": "{color.neutral.950}", "$type": "color" },
          "secondary": { "$value": "{color.neutral.700}", "$type": "color" },
          "tertiary":  { "$value": "{color.neutral.500}", "$type": "color" },
          "disabled":  { "$value": "{color.neutral.300}", "$type": "color" },
          "link":      { "$value": "{color.brand.primary.700}", "$type": "color" }
        },
        "border": {
          "subtle": { "$value": "{color.neutral.100}", "$type": "color" },
          "default":{ "$value": "{color.neutral.200}", "$type": "color" },
          "strong": { "$value": "{color.neutral.400}", "$type": "color" },
          "focus":  { "$value": "{color.brand.primary.500}", "$type": "color" }
        },
        "toolbar": {
          "background":      { "$value": "{color.neutral.50}",  "$type": "color" },
          "tab.active.background":   { "$value": "{color.neutral.0}",   "$type": "color" },
          "tab.inactive.background": { "$value": "{color.neutral.100}", "$type": "color" }
        },
        "status": {
          "success": { "$value": "{color.semantic.success}", "$type": "color" },
          "warning": { "$value": "{color.semantic.warning}", "$type": "color" },
          "error":   { "$value": "{color.semantic.error}",   "$type": "color" },
          "info":    { "$value": "{color.semantic.info}",    "$type": "color" }
        },
        "chart": {
          "1": { "$value": "#3B82F6", "$type": "color" },
          "2": { "$value": "#8B5CF6", "$type": "color" },
          "3": { "$value": "#10B981", "$type": "color" },
          "4": { "$value": "#F59E0B", "$type": "color" },
          "5": { "$value": "#EF4444", "$type": "color" }
        }
      }
    },

    "syntax": {
      "$description": "Code editor / Markdown 코드블록 syntax highlight tokens (tree-sitter scope mapping)",
      "keyword":  { "$value": "#C792EA", "$type": "color" },
      "string":   { "$value": "#C3E88D", "$type": "color" },
      "number":   { "$value": "#F78C6C", "$type": "color" },
      "comment":  { "$value": "#546E7A", "$type": "color" },
      "function": { "$value": "#82AAFF", "$type": "color" },
      "type":     { "$value": "#FFCB6B", "$type": "color" },
      "variable": { "$value": "#EEFFFF", "$type": "color" },
      "operator": { "$value": "#89DDFF", "$type": "color" },
      "constant": { "$value": "#F07178", "$type": "color" },
      "tag":      { "$value": "#F07178", "$type": "color" },
      "attribute":{ "$value": "#FFCB6B", "$type": "color" }
    }
  },

  "typography": {
    "fontFamily": {
      "sans":  { "$value": ["Pretendard", "Inter", "system-ui", "-apple-system", "Segoe UI", "Roboto", "sans-serif"], "$type": "fontFamily", "$description": "Primary UI font — 한글 우선 Pretendard, 영문 fallback Inter." },
      "mono":  { "$value": ["JetBrains Mono", "Fira Code", "SF Mono", "Menlo", "Consolas", "monospace"], "$type": "fontFamily", "$description": "Code / terminal font — ligature 지원." },
      "serif": { "$value": ["Charter", "Iowan Old Style", "Georgia", "serif"], "$type": "fontFamily", "$description": "Markdown 본문 옵션 (선택적)." }
    },
    "fontSize": {
      "xs":   { "$value": "11px", "$type": "dimension" },
      "sm":   { "$value": "12px", "$type": "dimension" },
      "base": { "$value": "14px", "$type": "dimension", "$description": "Default UI body / code editor." },
      "md":   { "$value": "16px", "$type": "dimension" },
      "lg":   { "$value": "18px", "$type": "dimension" },
      "xl":   { "$value": "20px", "$type": "dimension" },
      "2xl":  { "$value": "24px", "$type": "dimension" },
      "3xl":  { "$value": "30px", "$type": "dimension" },
      "4xl":  { "$value": "36px", "$type": "dimension" },
      "5xl":  { "$value": "48px", "$type": "dimension" }
    },
    "fontWeight": {
      "regular":  { "$value": 400, "$type": "fontWeight" },
      "medium":   { "$value": 500, "$type": "fontWeight" },
      "semibold": { "$value": 600, "$type": "fontWeight" },
      "bold":     { "$value": 700, "$type": "fontWeight" }
    },
    "lineHeight": {
      "tight":   { "$value": 1.2,  "$type": "number" },
      "normal":  { "$value": 1.5,  "$type": "number" },
      "relaxed": { "$value": 1.75, "$type": "number" }
    },
    "letterSpacing": {
      "tight":  { "$value": "-0.01em", "$type": "dimension" },
      "normal": { "$value": "0",       "$type": "dimension" },
      "wide":   { "$value": "0.02em",  "$type": "dimension" }
    }
  },

  "spacing": {
    "$description": "4-base scale, used for padding/margin/gap.",
    "0":  { "$value": "0",    "$type": "dimension" },
    "1":  { "$value": "4px",  "$type": "dimension" },
    "2":  { "$value": "8px",  "$type": "dimension" },
    "3":  { "$value": "12px", "$type": "dimension" },
    "4":  { "$value": "16px", "$type": "dimension" },
    "5":  { "$value": "20px", "$type": "dimension" },
    "6":  { "$value": "24px", "$type": "dimension" },
    "8":  { "$value": "32px", "$type": "dimension" },
    "10": { "$value": "40px", "$type": "dimension" },
    "12": { "$value": "48px", "$type": "dimension" },
    "16": { "$value": "64px", "$type": "dimension" },
    "20": { "$value": "80px", "$type": "dimension" },
    "24": { "$value": "96px", "$type": "dimension" }
  },

  "radius": {
    "none": { "$value": "0",    "$type": "dimension" },
    "sm":   { "$value": "4px",  "$type": "dimension" },
    "md":   { "$value": "6px",  "$type": "dimension", "$description": "Default — buttons, inputs, cards." },
    "lg":   { "$value": "8px",  "$type": "dimension" },
    "xl":   { "$value": "12px", "$type": "dimension" },
    "2xl":  { "$value": "16px", "$type": "dimension" },
    "full": { "$value": "9999px","$type": "dimension" }
  },

  "shadow": {
    "$description": "Elevation scale (dark-theme adjusted; light-theme reduces alpha).",
    "0": { "$value": "none", "$type": "shadow" },
    "1": { "$value": "0 1px 2px rgba(0,0,0,0.30)", "$type": "shadow" },
    "2": { "$value": "0 2px 4px rgba(0,0,0,0.35)", "$type": "shadow" },
    "3": { "$value": "0 4px 8px rgba(0,0,0,0.40)", "$type": "shadow" },
    "4": { "$value": "0 8px 16px rgba(0,0,0,0.45)","$type": "shadow" },
    "5": { "$value": "0 16px 32px rgba(0,0,0,0.50)","$type": "shadow" }
  },

  "zIndex": {
    "base":     { "$value": 0,    "$type": "number" },
    "tabs":     { "$value": 10,   "$type": "number" },
    "sidebar":  { "$value": 20,   "$type": "number" },
    "toolbar":  { "$value": 30,   "$type": "number" },
    "dropdown": { "$value": 100,  "$type": "number" },
    "popover":  { "$value": 200,  "$type": "number" },
    "modal":    { "$value": 1000, "$type": "number" },
    "toast":    { "$value": 2000, "$type": "number" }
  },

  "motion": {
    "duration": {
      "instant": { "$value": "0ms",   "$type": "duration" },
      "fast":    { "$value": "120ms", "$type": "duration" },
      "normal":  { "$value": "200ms", "$type": "duration" },
      "slow":    { "$value": "320ms", "$type": "duration" }
    },
    "easing": {
      "linear":      { "$value": "linear", "$type": "cubicBezier" },
      "easeOut":     { "$value": "cubic-bezier(0.16, 1, 0.3, 1)",   "$type": "cubicBezier" },
      "easeInOut":   { "$value": "cubic-bezier(0.4, 0, 0.2, 1)",     "$type": "cubicBezier" },
      "spring":      { "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)","$type": "cubicBezier", "$description": "탭/패널 transition." }
    }
  },

  "breakpoints": {
    "$description": "Desktop-first IDE — responsive 는 최소 유지 (모바일 비목표).",
    "compact": { "$value": "1024px", "$type": "dimension" },
    "default": { "$value": "1440px", "$type": "dimension" },
    "wide":    { "$value": "1920px", "$type": "dimension" }
  },

  "component": {
    "button": {
      "padding.x":     { "$value": "{spacing.3}", "$type": "dimension" },
      "padding.y":     { "$value": "{spacing.2}", "$type": "dimension" },
      "radius":        { "$value": "{radius.md}", "$type": "dimension" },
      "fontWeight":    { "$value": "{typography.fontWeight.medium}", "$type": "fontWeight" },
      "fontSize":      { "$value": "{typography.fontSize.base}",     "$type": "dimension" }
    },
    "input": {
      "padding.x":     { "$value": "{spacing.3}", "$type": "dimension" },
      "padding.y":     { "$value": "{spacing.2}", "$type": "dimension" },
      "radius":        { "$value": "{radius.md}", "$type": "dimension" },
      "borderWidth":   { "$value": "1px",         "$type": "dimension" }
    },
    "card": {
      "padding":       { "$value": "{spacing.4}", "$type": "dimension" },
      "radius":        { "$value": "{radius.lg}", "$type": "dimension" },
      "shadow":        { "$value": "{shadow.2}",  "$type": "shadow" }
    },
    "tab": {
      "height":        { "$value": "32px",        "$type": "dimension" },
      "padding.x":     { "$value": "{spacing.3}", "$type": "dimension" },
      "radius":        { "$value": "{radius.sm}", "$type": "dimension" },
      "active.fontWeight":   { "$value": "{typography.fontWeight.semibold}", "$type": "fontWeight" },
      "inactive.fontWeight": { "$value": "{typography.fontWeight.regular}",  "$type": "fontWeight" }
    },
    "pane": {
      "minWidth":      { "$value": "240px",       "$type": "dimension" },
      "minHeight":     { "$value": "120px",       "$type": "dimension" },
      "divider.thickness": { "$value": "4px",     "$type": "dimension" },
      "divider.hover.color":{ "$value": "{color.brand.primary.500}", "$type": "color" }
    },
    "sidebar": {
      "width":         { "$value": "240px",       "$type": "dimension" },
      "minWidth":      { "$value": "180px",       "$type": "dimension" },
      "maxWidth":      { "$value": "480px",       "$type": "dimension" }
    },
    "explorer": {
      "indent":        { "$value": "{spacing.4}", "$type": "dimension" },
      "icon.size":     { "$value": "16px",        "$type": "dimension" },
      "row.height":    { "$value": "24px",        "$type": "dimension" }
    },
    "terminal": {
      "fontSize":      { "$value": "{typography.fontSize.base}", "$type": "dimension" },
      "lineHeight":    { "$value": 1.4,                          "$type": "number" },
      "fontFamily":    { "$value": "{typography.fontFamily.mono}","$type": "fontFamily" }
    },
    "viewer.markdown": {
      "fontSize":      { "$value": "{typography.fontSize.md}",   "$type": "dimension" },
      "lineHeight":    { "$value": "{typography.lineHeight.relaxed}", "$type": "number" },
      "maxWidth":      { "$value": "780px",                      "$type": "dimension" },
      "code.fontSize": { "$value": "{typography.fontSize.sm}",   "$type": "dimension" }
    },
    "agent.dashboard": {
      "event.fontSize":{ "$value": "{typography.fontSize.sm}",   "$type": "dimension" },
      "event.lineHeight":{ "$value": "{typography.lineHeight.normal}","$type": "number" },
      "cost.chart.height": { "$value": "180px",                  "$type": "dimension" }
    }
  },

  "claude_design_handoff": {
    "$description": "/moai design path A (Claude Design import) 사용 시 이 섹션이 handoff bundle 으로 export 된다.",
    "platform": "cross-platform desktop (macOS / Linux / Windows)",
    "framework": "GPUI 0.2.2 (Rust)",
    "theme_strategy": "dark-first, light alternative",
    "language_support": "한국어 + English (bilingual)",
    "key_constraints": [
      "60fps@4K rendering (terminal/code editor 핵심)",
      "WCAG 2.1 AA 접근성 (cross-platform 동등)",
      "키보드 우선 navigation (developer IDE)",
      "모바일/태블릿 비목표 (desktop only)"
    ],
    "vision_keywords": [
      "agentic coding",
      "moai-adk integration",
      "multi-pane / multi-tab",
      "terminal-dominant",
      "AI hook visualization"
    ]
  }
}
