    "$description": "Round 2 (P1 신규 의뢰) 컴포넌트 dimensions — moai-revisions.jsx + moai-studio.html 시안 정합. Claude Design Round 2 산출 (.moai/design/from-claude-design/project/moai-revisions.jsx 18 component).",

    "palette": {
      "$description": "Cmd+P / Cmd+Shift+P / /moai * 슬래시 Command Palette (.pal).",
      "width":         { "$value": "min(600px, 92%)", "$type": "dimension" },
      "input.height":  { "$value": "44px",  "$type": "dimension" },
      "input.fontSize":{ "$value": "13px",  "$type": "dimension", "$description": "mono font, letter-spacing -0.01em" },
      "row.height":    { "$value": "32px",  "$type": "dimension" },
