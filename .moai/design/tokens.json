      "primary.dark.hover": { "$value": "#2bafa3", "$type": "color" },
      "ink":            { "$value": "#09110f", "$type": "color", "$description": "본문 텍스트 (#000 대체)" },
      "bg":             { "$value": "#f3f3f3", "$type": "color", "$description": "페이지 배경 (#fff 대체 금지)" },
