# ============================================
# MoAI Studio .gitignore
# ============================================
# Project: Swift (UI) + Rust (Core) macOS App
# Updated: 2026-04-12
# ============================================

# ===========================================
# OS Files
# ===========================================
.DS_Store
.AppleDouble
.LSOverride
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
[Dd]esktop.ini
Thumbs.db
.directory

# ===========================================
# IDE & Editors
# ===========================================
.vscode/
.idea/
.cursor/
*.swp
*.swo
*.sw?
*~
.#*

# ===========================================
# Swift / Xcode
# ===========================================
DerivedData/
*.xcuserdata
xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/
*.dSYM/
*.o
*.a

# xcframework 빌드 산출물 (app/Frameworks/ 는 .gitkeep 으로만 추적)
app/Frameworks/*.xcframework
app/Frameworks/*/
!app/Frameworks/.gitkeep

# ===========================================
# Rust
# ===========================================
target/
Cargo.lock
.cargo/
*.profraw
*.profdata

# ===========================================
# Build Artifacts
# ===========================================
build/
dist/

# ===========================================
# Logs & Temporary Files
# ===========================================
*.log
logs/
*.tmp
*.temp
*.bak

# ===========================================
# Secrets and Credentials
# ===========================================
.env
.env.*
!.env.example
*.pem
*.p12
*.pfx
private-key*
*-api-key.*
*-secret-key.*
secret-key-*
.aws/config
.aws/credentials

# ===========================================
# Claude Code Configuration
# ===========================================
.claude/settings.local.json
.claude/settings.local.*.json
.claude/.env.local*
.claude/local/
.claude/plans/
.claude/agent-memory/
.claude/worktrees/
.claude/skills/*/.env*
.claude/skills/*/secrets/

# ===========================================
# MoAI Local State (never commit)
# ===========================================
.moai/status_line.sh
.moai/memory/
.moai/worktrees/
.moai/cache/
.moai/logs/
.moai/state/
.moai/reports/
.moai/manifest.json
.moai-backups/

# ===========================================
# Reference Symlinks (local dev only)
# ===========================================
.references/

# ===========================================
# Test Coverage
# ===========================================
coverage/
htmlcov/
.coverage
coverage.json

# ===========================================
# Node.js (docs/Nextra only)
# ===========================================
node_modules/
.next/
out/
app/.build/
